# HermuXclaw-CORE Environment Template
# Copy to .env and fill in production credentials

# System Configuration
HX_PORT=8013
HX_DB_PATH=memory/registry.db
LOG_LEVEL=INFO

# Integration Credentials (Pravidhi Client Projects)
SAP_URL=https://your-sap-instance.com
WA_TOKEN=your_whatsapp_business_api_token
WA_PHONE_ID=your_whatsapp_phone_number_id
ZOHO_TOKEN=your_zoho_crm_access_token
OPENAI_KEY=your_openai_api_key

# Database Connections
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=pravidhi_ml
PG_USER=postgres
PG_PASSWORD=your_password
